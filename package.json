{
  "name": "gif",
  "version": "1.0.0",
  "description": "UI for searching gifs using Klipy",
  "keywords": [
    "gif",
    "search",
    "klipy",
    "ui"
  ],
  "homepage": "https://github.com/crudh/gif",
  "bugs": {
